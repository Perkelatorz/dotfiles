# Work: NVIDIA-primary on Quadro P4000/P2000 (Pascal, legacy 580xx driver).

env = LIBVA_DRIVER_NAME,nvidia
env = NVD_BACKEND,direct
env = __GLX_VENDOR_LIBRARY_NAME,nvidia

# Pascal + Wayland is more cursor-glitch-prone than newer cards; if the cursor
# vanishes or flickers, uncomment:
# cursor:no_hardware_cursors = true
