#!/bin/bash
set -euo pipefail

# yadm bootstrap — CachyOS (fresh, NO desktop selected) → Hyprland workstation.
#
# Fresh machine:
#   sudo pacman -S --needed git yadm
#   yadm clone https://github.com/perkelatorz/dotfiles
#   yadm config local.class desktop|laptop|work     # (bootstrap prompts if unset)
#   yadm bootstrap
#   reboot                                          # lands in SDDM → Hyprland
#
# Classes (drive package lists in packages/class/ and ##class config alternates):
#   desktop  — home desktop: nvidia-open, Sunshine game-stream host
#   laptop   — hybrid AMD iGPU + NVIDIA dGPU (prime-run offload)
#   work     — Pascal Quadros (legacy 580xx driver), xrdp for RDP access
#
# Env flags:
#   BOOTSTRAP_SKIP_UPGRADE=1   Skip full system upgrade (pacman -Syu). Not
#                              recommended on fresh installs — installing on a
#                              synced-but-not-upgraded system is a partial upgrade.
#   CLAUDE_CODE_SKIP=1         Skip Claude Code CLI install.
#
# Idempotent: every step is safe to re-run; --needed skips installed packages.

PKG_DIR="$HOME/.config/yadm/packages"
SECRETS_FILE="$HOME/.config/nvim/secrets.lua"
MATUGEN_THEMES_DIR="$HOME/.config/matugen-themes"

CLASS=""
FAILED_PKGS=()

info() { echo "🔷 $*"; }
ok()   { echo "   ✓ $*"; }
warn() { echo "   ⚠️  $*"; }

read_pkg_file() {
    # Emit non-empty, non-comment lines from a package list.
    grep -Ev '^[[:space:]]*(#|$)' "$1" 2>/dev/null || true
}

# --- class ---

ensure_class() {
    CLASS=$(yadm config local.class 2>/dev/null || true)
    if [[ -z "$CLASS" ]]; then
        local -a classes
        mapfile -t classes < <(basename -s .pkgs "$PKG_DIR"/class/*.pkgs)
        if [[ ! -t 0 ]]; then
            echo "❌ No machine class set and no TTY to ask."
            echo "   Run: yadm config local.class <$(IFS='|'; echo "${classes[*]}")> && yadm bootstrap"
            exit 1
        fi
        echo "This machine has no class yet. Available: ${classes[*]}"
        read -rp "Class for this machine: " CLASS
        if [[ ! -f "$PKG_DIR/class/$CLASS.pkgs" ]]; then
            echo "❌ No package list for class '$CLASS' ($PKG_DIR/class/$CLASS.pkgs)"
            exit 1
        fi
        yadm config local.class "$CLASS"
    fi
    ok "machine class: $CLASS"
    # Copy alternates instead of symlinking: yadm's auto-alt (runs on most yadm
    # commands) recreates symlinks, and the delete+create gap kills Hyprland's
    # inotify watch on sourced files (latches "source= globbing error"). A copy
    # is overwritten in place — same inode, watch survives.
    yadm config yadm.alt-copy true
    # Materialize ##class./##hostname. alternates (e.g. hypr/env-gpu.conf) now
    # that the class is known.
    # (hooks/post_alt reloads Hyprland if live — alt's relink otherwise latches
    # a "source= globbing error" until reload)
    yadm alt >/dev/null 2>&1 && ok "yadm alternates refreshed" || warn "yadm alt failed"
}

# --- package installation ---

# Bulk install with --needed; if the transaction fails (one bad package, a
# provider conflict, ...), fall back to one-at-a-time so the rest still lands.
# stdin </dev/null auto-picks the default provider on "N providers available"
# prompts that --noconfirm alone won't answer.
install_repo_pkgs() {
    local -a pkgs=("$@")
    (( ${#pkgs[@]} )) || return 0
    info "Installing ${#pkgs[@]} repo package(s)..."
    if sudo pacman -S --needed --noconfirm "${pkgs[@]}" </dev/null; then
        return 0
    fi
    warn "bulk install failed; retrying one at a time"
    for p in "${pkgs[@]}"; do
        sudo pacman -S --needed --noconfirm "$p" </dev/null \
            || { warn "pacman failed: $p"; FAILED_PKGS+=("$p"); }
    done
}

# AUR via paru. paru itself comes from the CachyOS repo — nothing is built
# from the AUR except the listed packages themselves.
install_aur_pkgs() {
    local -a pkgs=("$@")
    (( ${#pkgs[@]} )) || return 0
    command -v paru &>/dev/null || sudo pacman -S --needed --noconfirm paru
    info "Installing ${#pkgs[@]} AUR package(s)..."
    # --skipreview: paru's PKGBUILD review prompt stalls scripted runs.
    for p in "${pkgs[@]}"; do
        paru -S --needed --noconfirm --skipreview --sudoloop "$p" \
            || { warn "paru failed: $p"; FAILED_PKGS+=("$p"); }
    done
}

install_packages() {
    local -a repo_pkgs=() aur_pkgs=()
    local f
    for f in "$PKG_DIR"/*.pkgs "$PKG_DIR/class/$CLASS.pkgs"; do
        [[ -f "$f" ]] || continue
        mapfile -t -O "${#repo_pkgs[@]}" repo_pkgs < <(read_pkg_file "$f")
        ok "list: $(basename "$f")"
    done
    if [[ -f "$PKG_DIR/class/$CLASS.aur" ]]; then
        mapfile -t aur_pkgs < <(read_pkg_file "$PKG_DIR/class/$CLASS.aur")
        (( ${#aur_pkgs[@]} )) && ok "list: class/$CLASS.aur (AUR)"
    fi
    mapfile -t repo_pkgs < <(printf '%s\n' "${repo_pkgs[@]}" | awk '!seen[$0]++')

    install_repo_pkgs "${repo_pkgs[@]}"
    install_aur_pkgs "${aur_pkgs[@]}"
}

# --- services ---

enable_system_service() {
    local svc="$1" now="${2:-}"
    if ! systemctl list-unit-files "$svc.service" &>/dev/null; then
        warn "$svc.service not present; skipping"
        return
    fi
    local -a cmd=(sudo systemctl enable)
    [[ "$now" == "--now" ]] && cmd+=(--now)
    if "${cmd[@]}" "$svc" &>/dev/null; then
        ok "$svc enabled${now:+ + started}"
    else
        warn "failed: sudo systemctl enable $now $svc"
    fi
}

setup_services() {
    info "Enabling services..."
    enable_system_service NetworkManager --now
    enable_system_service bluetooth --now
    enable_system_service tailscaled --now
    # sddm: enable only — starting it now would tear down this TTY mid-bootstrap.
    enable_system_service sddm

    case "$CLASS" in
        desktop)
            # Sunshine's user unit keeps its upstream flatpak-style name. Needs a
            # session bus (fails harmlessly over bare ssh — re-run after first
            # graphical login).
            local sunshine_unit="app-dev.lizardbyte.app.Sunshine.service"
            if systemctl --user enable "$sunshine_unit" &>/dev/null; then
                ok "sunshine user service enabled (pair via https://localhost:47990)"
            else
                warn "sunshine not enabled — run: systemctl --user enable --now $sunshine_unit"
            fi
            ;;
        work)
            enable_system_service xrdp --now
            enable_system_service xrdp-sesman --now
            ;;
    esac

    if command -v tailscale &>/dev/null && ! tailscale status &>/dev/null; then
        echo "   ℹ️  Tailscale not authed yet — run: sudo tailscale up"
    fi
}

# --- one-time machine setup ---

setup_default_shell_zsh() {
    local zsh_path current
    zsh_path=$(command -v zsh) || { warn "zsh missing"; return; }
    current=$(getent passwd "$USER" | cut -d: -f7)
    [[ "$current" == "$zsh_path" || "$current" == "/bin/zsh" ]] && return
    info "Default shell → zsh..."
    chsh -s "$zsh_path" && ok "shell set (takes effect next login)" || warn "chsh failed"
}

setup_neovim_secrets() {
    [[ -f "$SECRETS_FILE" ]] && return
    info "Neovim secrets stub..."
    mkdir -p "$(dirname "$SECRETS_FILE")"
    cat > "$SECRETS_FILE" <<'EOF'
return {
  ANTHROPIC_API_KEY = "your-anthropic-key-here",
  OPENAI_API_KEY = "your-openai-key-here",
}
EOF
    ok "created $SECRETS_FILE — add real keys"
}

setup_matugen_themes() {
    [[ -d "$MATUGEN_THEMES_DIR/.git" ]] && return
    if [[ -d "$MATUGEN_THEMES_DIR" ]]; then
        warn "$MATUGEN_THEMES_DIR exists but is not a git repo; skipping"
        return
    fi
    info "Cloning matugen-themes (select-wallpaper.sh needs it)..."
    git clone --depth 1 https://github.com/InioX/matugen-themes.git "$MATUGEN_THEMES_DIR" \
        || warn "clone failed"
}

install_claude_code_cli() {
    [[ "${CLAUDE_CODE_SKIP:-}" == "1" ]] && return
    if command -v claude &>/dev/null || [[ -x "$HOME/.local/bin/claude" ]]; then
        return
    fi
    info "Installing Claude Code CLI..."
    curl -fsSL https://claude.ai/install.sh | bash \
        && ok "installed (ensure ~/.local/bin on PATH)" \
        || warn "install failed — retry: curl -fsSL https://claude.ai/install.sh | bash"
}

# Headless nvim run so vim.pack pulls plugins (Mason finishes later in :Mason).
warm_neovim_plugins() {
    command -v nvim &>/dev/null || return 0
    [[ -f "$HOME/.config/nvim/init.lua" ]] || return 0
    info "Warming Neovim plugins (headless)..."
    if nvim --headless -c 'qa' &>/dev/null; then
        ok "vim.pack done — open nvim and :Mason for LSP binaries"
    else
        warn "headless nvim exited non-zero (usually fine on first run)"
    fi
}

# --- work-only: RDP session (xrdp → XFCE) ---
# Stock /etc/xrdp/startwm.sh reads ~/.xinitrc (NOT ~/.xsession). Strips
# Wayland/Hyprland env so XFCE/dbus start clean; kills stale xfconfd left by a
# local Hyprland session sharing $HOME.
setup_rdp_session() {
    info "RDP session (xrdp → XFCE)..."
    if ! command -v startxfce4 &>/dev/null; then
        warn "startxfce4 missing — xfce4 group failed to install?"
        return
    fi
    local xi="$HOME/.xinitrc"
    local marker="# managed by yadm bootstrap (rdp-xfce)"
    if [[ -f "$xi" ]] && ! grep -qF "$marker" "$xi"; then
        cp "$xi" "$xi.bak.$(date +%s)"
        warn "backed up existing $xi"
    fi
    cat >"$xi" <<EOF
#!/bin/sh
$marker
# Sourced by /etc/xrdp/startwm.sh on RDP login (sourced, not exec'd), so we
# exec startxfce4 to take over the process.

# Strip Wayland/Hyprland env leaked from local session profile.
unset WAYLAND_DISPLAY HYPRLAND_INSTANCE_SIGNATURE HYPRLAND_CMD
export XDG_SESSION_TYPE=x11
export XDG_CURRENT_DESKTOP=XFCE

# Kill stale xfconfd from local session (same \$HOME = same xfconf cache).
killall xfconfd 2>/dev/null || true

exec dbus-run-session -- startxfce4
EOF
    chmod +x "$xi"
    ok "wrote $xi"

    if [[ -f /etc/xrdp/startwm.sh ]] && ! grep -q '~/.xinitrc' /etc/xrdp/startwm.sh; then
        warn "/etc/xrdp/startwm.sh does not reference ~/.xinitrc — patch needed"
    fi
    cat <<'EOF'
   ℹ️  RDP notes:
      • Firewall: open 3389/tcp if one is active.
      • Windows: mstsc → <host>:3389 → Linux creds → session type "Xorg".
      • Log out of local Hyprland before RDP-ing as the same user (or use a
        dedicated user) — shared $HOME means xfconfd/Thunar conflicts.
EOF
}

# --- Hyprland plugins (interactive; needs hyprland installed) ---
setup_hyprland_plugins() {
    local -a plugins=(https://github.com/Duckonaut/split-monitor-workspaces)
    # NEVER run hyprpm as root — it writes /var/cache/hyprpm/$USER and elevates
    # internally for header installs; running as root breaks later user calls.
    [[ $EUID -eq 0 ]] && { warn "refusing to run hyprpm as root"; return 1; }
    info "Hyprland plugins..."
    hyprpm update || { warn "hyprpm update failed"; return 1; }
    local url name
    for url in "${plugins[@]}"; do
        name=$(basename "$url" .git)
        hyprpm add "$url"     || { warn "add $name failed"; continue; }
        hyprpm enable "$name" || { warn "enable $name failed"; continue; }
    done
    hyprpm reload 2>/dev/null || true
    ok "plugins done"
}

# --- main ---

echo "🚀 CachyOS → Hyprland bootstrap"
[[ -d "$PKG_DIR" ]] || { echo "❌ $PKG_DIR not found"; exit 1; }
sudo -v || { echo "❌ sudo required"; exit 1; }

ensure_class

if [[ "${BOOTSTRAP_SKIP_UPGRADE:-}" == "1" ]]; then
    info "Syncing package databases (upgrade skipped)..."
    sudo pacman -Sy --noconfirm
else
    info "Full system upgrade (pacman -Syu)..."
    sudo pacman -Syu --noconfirm
fi

install_packages
setup_services
setup_default_shell_zsh
setup_neovim_secrets
setup_matugen_themes
install_claude_code_cli
warm_neovim_plugins
[[ "$CLASS" == "work" ]] && setup_rdp_session

if [[ -t 0 ]] && command -v hyprpm &>/dev/null; then
    read -rp "Build Hyprland plugins now? (y/N): " choice
    [[ "${choice,,}" == y* ]] && setup_hyprland_plugins || echo "⏭️  Skipped (re-run bootstrap or 'hyprpm update' later)"
fi

echo
echo "✨ Bootstrap complete (class: $CLASS)"
if (( ${#FAILED_PKGS[@]} )); then
    echo "⚠️  ${#FAILED_PKGS[@]} package(s) failed:"
    printf '   ✗ %s\n' "${FAILED_PKGS[@]}"
    # NVIDIA failures on an already-installed machine = driver-branch conflict
    # (e.g. 580xx installed, list wants open). --noconfirm won't remove the old
    # branch; the swap needs an interactive run.
    mapfile -t nvidia_failed < <(printf '%s\n' "${FAILED_PKGS[@]}" | grep -E '^(lib32-)?nvidia' || true)
    if (( ${#nvidia_failed[@]} )); then
        echo "   ℹ️  NVIDIA branch swap needs interactive confirmation:"
        echo "      sudo pacman -S ${nvidia_failed[*]}"
        echo "      (answer y to remove the old driver branch, then reboot)"
    fi
fi
echo "➡️  Next: reboot → SDDM → Hyprland. Then: sudo tailscale up (if new machine)."
